APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_RUN_TTL_SECONDS=86400

# LLM provider keys (set whichever you use)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Default model used when agent has no model set
LLM_DEFAULT_MODEL=claude-sonnet-4-5
# Cost/perf strategy: "cheapest" | "fastest" | "smartest" | "balanced"
LLM_SELECTION_STRATEGY=balanced

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://flowforge:secret@localhost:5432/flowforge
# Sync URL used only by Alembic migrations
DATABASE_SYNC_URL=postgresql+psycopg2://flowforge:secret@localhost:5432/flowforge
